# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/liveorder?sslmode=require

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# PortOne (PG)
NEXT_PUBLIC_PORTONE_STORE_ID=store_xxxxxxxxxxxx
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxxxxxx
PORTONE_API_SECRET=your-portone-api-secret

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Cron
CRON_SECRET=your-cron-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_RATE=0.025
SETTLEMENT_DELAY_DAYS=3
